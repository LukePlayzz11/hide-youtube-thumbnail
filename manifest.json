{
  "manifest_version": 3,
  "name": "Hide YouTube Thumbnails v2",
  "short_name": "HYT v2",
  "version": "2.0.0",
  "description": "Hide all video thumbnails on YouTube (keeps clean layout + main player untouched)",
  "author": "Your Name",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hide YouTube Thumbnails v2"
  }
}
